# Bloque de configuracion del servidor HTTP
PORT=3000
CLIENT_ORIGIN=http://127.0.0.1:5500
NODE_ENV=development
FORCE_HTTPS=false

# Bloque de configuracion de base de datos MySQL
DB_CLIENT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=tienda_redes

# Bloque de configuracion para Supabase (PostgreSQL)
SUPABASE_DB_HOST=db.tu-proyecto.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu_password_supabase
SUPABASE_DB_NAME=postgres
SUPABASE_DB_SSL=true
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key

# Bloque de autenticacion JWT (separacion de secretos por tipo de token)
JWT_ACCESS_SECRET=tu_access_secret_super_seguro
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=tu_refresh_secret_super_seguro
JWT_REFRESH_EXPIRES_IN=7d

# Bloque de cookies de sesion
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
